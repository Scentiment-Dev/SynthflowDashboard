{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscription Business Value Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module",
    "generated_from_fixture",
    "source_of_truth_system",
    "source_confirmation_status",
    "scenario",
    "metrics",
    "metadata"
  ],
  "properties": {
    "module": { "type": "string", "const": "subscriptions" },
    "generated_from_fixture": { "type": "boolean", "const": true },
    "source_of_truth_system": { "type": "string", "enum": ["stayai"] },
    "source_confirmation_status": { "type": "string", "enum": ["confirmed", "pending", "missing"] },
    "scenario": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric_key",
          "display_name",
          "value",
          "unit",
          "state",
          "formula",
          "source_of_truth",
          "data_dependencies",
          "notes"
        ],
        "properties": {
          "metric_key": { "type": "string" },
          "display_name": { "type": "string" },
          "value": { "type": ["number", "integer", "null"] },
          "unit": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["confirmed", "estimated", "unknown", "pending", "blocked_by_data"]
          },
          "formula": { "type": "string" },
          "source_of_truth": { "type": "string" },
          "data_dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "filters",
        "trust_label",
        "freshness_status",
        "formula_version",
        "owner",
        "timestamp",
        "fingerprint",
        "audit_reference",
        "blocked_metrics_count",
        "source_confirmation_status",
        "presentation"
      ],
      "properties": {
        "metric_id": { "type": "string" },
        "filters": { "type": "object" },
        "trust_label": { "type": "string", "enum": ["high", "medium", "low", "untrusted"] },
        "freshness_status": { "type": "string", "enum": ["fresh", "stale", "unknown"] },
        "formula_version": { "type": "string" },
        "owner": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fingerprint": { "type": "string" },
        "audit_reference": { "type": "string" },
        "blocked_metrics_count": { "type": "integer", "minimum": 0 },
        "source_confirmation_status": {
          "type": "string",
          "enum": ["confirmed", "pending", "missing"]
        },
        "presentation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "display_label",
            "short_label",
            "executive_summary",
            "format_type",
            "unit",
            "trend_direction",
            "comparison_label",
            "comparison_value",
            "severity",
            "visual_tone",
            "source_authority_explanation",
            "trust_explanation",
            "freshness_explanation",
            "drilldown_hint",
            "empty_state_copy",
            "blocked_state_copy"
          ],
          "properties": {
            "display_label": { "type": "string" },
            "short_label": { "type": "string" },
            "executive_summary": { "type": "string" },
            "format_type": { "type": "string" },
            "unit": { "type": "string" },
            "trend_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
            "comparison_label": { "type": "string" },
            "comparison_value": { "type": ["number", "null"] },
            "severity": { "type": "string", "enum": ["info", "success", "warning", "critical"] },
            "visual_tone": { "type": "string", "enum": ["neutral", "positive", "caution", "critical"] },
            "source_authority_explanation": { "type": "string" },
            "trust_explanation": { "type": "string" },
            "freshness_explanation": { "type": "string" },
            "drilldown_hint": { "type": "string" },
            "empty_state_copy": { "type": "string" },
            "blocked_state_copy": { "type": "string" }
          }
        }
      }
    }
  }
}
