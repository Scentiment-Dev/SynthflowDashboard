{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscription Analytics Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module",
    "generated_from_fixture",
    "final_subscription_state",
    "source_of_truth_system",
    "source_confirmation_status",
    "subscription_overview",
    "portal_journey",
    "shopify_context",
    "synthflow_journey",
    "source_confirmation",
    "metric_metadata"
  ],
  "properties": {
    "module": {
      "type": "string",
      "const": "subscriptions"
    },
    "generated_from_fixture": {
      "type": "boolean"
    },
    "final_subscription_state": {
      "type": "string",
      "enum": ["active", "retained", "saved", "cancelled", "pending", "unknown"]
    },
    "source_of_truth_system": {
      "type": "string",
      "enum": ["stayai"]
    },
    "source_confirmation_status": {
      "type": "string",
      "enum": ["confirmed", "pending", "missing"]
    },
    "subscription_overview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subscription_overview_count",
        "cancellation_requests_count",
        "confirmed_cancellations_count",
        "save_retention_attempts_count",
        "confirmed_retained_subscriptions_count",
        "pending_stayai_confirmation_count"
      ],
      "properties": {
        "subscription_overview_count": {
          "type": "integer",
          "minimum": 0
        },
        "cancellation_requests_count": {
          "type": "integer",
          "minimum": 0
        },
        "confirmed_cancellations_count": {
          "type": "integer",
          "minimum": 0
        },
        "save_retention_attempts_count": {
          "type": "integer",
          "minimum": 0
        },
        "confirmed_retained_subscriptions_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_stayai_confirmation_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "portal_journey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portal_link_sent_count", "confirmed_portal_completion_count"],
      "properties": {
        "portal_link_sent_count": {
          "type": "integer",
          "minimum": 0
        },
        "confirmed_portal_completion_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "shopify_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context_records_available_count", "context_role", "finalization_allowed"],
      "properties": {
        "context_records_available_count": {
          "type": "integer",
          "minimum": 0
        },
        "context_role": {
          "type": "string",
          "const": "context_only"
        },
        "finalization_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "synthflow_journey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["journey_event_count", "status_breakdown"],
      "properties": {
        "journey_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "status_breakdown": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "source_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_of_truth_system",
        "source_confirmation_status",
        "confirmed_records_count",
        "pending_records_count",
        "missing_records_count"
      ],
      "properties": {
        "source_of_truth_system": {
          "type": "string",
          "enum": ["stayai"]
        },
        "source_confirmation_status": {
          "type": "string",
          "enum": ["confirmed", "pending", "missing"]
        },
        "confirmed_records_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_records_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_records_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metric_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "metric_definitions",
        "filters",
        "formula_version",
        "freshness",
        "trust_label",
        "owner",
        "timestamp",
        "fingerprint",
        "audit_reference",
        "source_system",
        "source_confirmation_status"
      ],
      "properties": {
        "metric_id": {
          "type": "string"
        },
        "metric_definitions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "filters": {
          "type": "object"
        },
        "formula_version": {
          "type": "string"
        },
        "freshness": {
          "type": "string"
        },
        "trust_label": {
          "type": "string",
          "enum": ["high", "medium", "low", "untrusted"]
        },
        "owner": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "fingerprint": {
          "type": "string"
        },
        "audit_reference": {
          "type": "string"
        },
        "source_system": {
          "type": "string",
          "enum": ["stayai", "synthflow", "portal", "shopify", "warehouse", "analytics_api"]
        },
        "source_confirmation_status": {
          "type": "string",
          "enum": ["confirmed", "pending", "missing"]
        }
      }
    }
  }
}
