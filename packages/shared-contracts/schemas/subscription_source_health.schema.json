{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscription Source Health Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module",
    "generated_from_fixture",
    "overall_source_health",
    "conflict_status",
    "pending_or_unknown_final_outcome",
    "shopify_context_warning",
    "sources",
    "metadata"
  ],
  "properties": {
    "module": { "type": "string", "const": "subscriptions" },
    "generated_from_fixture": { "type": "boolean" },
    "overall_source_health": { "type": "string", "enum": ["healthy", "warning", "degraded", "unknown"] },
    "conflict_status": { "type": "string", "enum": ["none", "pending", "conflict_detected", "unknown"] },
    "pending_or_unknown_final_outcome": { "type": "boolean" },
    "missing_stay_ai_final_state_warning": { "type": ["string", "null"] },
    "portal_completion_warning": { "type": ["string", "null"] },
    "shopify_context_warning": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_system",
          "source_authority_level",
          "record_count",
          "last_seen_at",
          "freshness_status",
          "freshness_minutes",
          "source_confirmation_status",
          "data_quality_status",
          "conflict_count",
          "missing_required_fields",
          "lineage_reference",
          "owner",
          "formula_version",
          "audit_reference",
          "trust_label",
          "presentation"
        ],
        "properties": {
          "source_system": { "type": "string", "enum": ["stay_ai", "synthflow", "shopify", "portal"] },
          "source_authority_level": {
            "type": "string",
            "enum": [
              "authoritative_final_state",
              "journey_event_authoritative",
              "context_only",
              "completion_signal"
            ]
          },
          "record_count": { "type": "integer", "minimum": 0 },
          "last_seen_at": { "type": "string", "format": "date-time" },
          "freshness_status": { "type": "string", "enum": ["fresh", "stale", "unknown"] },
          "freshness_minutes": { "type": "integer", "minimum": 0 },
          "source_confirmation_status": { "type": "string", "enum": ["confirmed", "pending", "missing"] },
          "data_quality_status": { "type": "string", "enum": ["passing", "warning", "failing"] },
          "conflict_count": { "type": "integer", "minimum": 0 },
          "missing_required_fields": { "type": "array", "items": { "type": "string" } },
          "lineage_reference": { "type": "string" },
          "owner": { "type": "string" },
          "formula_version": { "type": "string" },
          "audit_reference": { "type": "string" },
          "trust_label": { "type": "string", "enum": ["high", "medium", "low", "untrusted"] },
          "presentation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "display_label",
              "short_label",
              "executive_summary",
              "format_type",
              "unit",
              "trend_direction",
              "comparison_label",
              "comparison_value",
              "severity",
              "visual_tone",
              "source_authority_explanation",
              "trust_explanation",
              "freshness_explanation",
              "drilldown_hint",
              "empty_state_copy",
              "blocked_state_copy"
            ],
            "properties": {
              "display_label": { "type": "string" },
              "short_label": { "type": "string" },
              "executive_summary": { "type": "string" },
              "format_type": { "type": "string" },
              "unit": { "type": "string" },
              "trend_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
              "comparison_label": { "type": "string" },
              "comparison_value": { "type": ["number", "null"] },
              "severity": { "type": "string", "enum": ["info", "success", "warning", "critical"] },
              "visual_tone": { "type": "string", "enum": ["neutral", "positive", "caution", "critical"] },
              "source_authority_explanation": { "type": "string" },
              "trust_explanation": { "type": "string" },
              "freshness_explanation": { "type": "string" },
              "drilldown_hint": { "type": "string" },
              "empty_state_copy": { "type": "string" },
              "blocked_state_copy": { "type": "string" }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "fingerprint", "formula_version", "owner", "audit_reference", "presentation"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "fingerprint": { "type": "string" },
        "formula_version": { "type": "string" },
        "owner": { "type": "string" },
        "audit_reference": { "type": "string" },
        "presentation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "display_label",
            "short_label",
            "executive_summary",
            "format_type",
            "unit",
            "trend_direction",
            "comparison_label",
            "comparison_value",
            "severity",
            "visual_tone",
            "source_authority_explanation",
            "trust_explanation",
            "freshness_explanation",
            "drilldown_hint",
            "empty_state_copy",
            "blocked_state_copy"
          ],
          "properties": {
            "display_label": { "type": "string" },
            "short_label": { "type": "string" },
            "executive_summary": { "type": "string" },
            "format_type": { "type": "string" },
            "unit": { "type": "string" },
            "trend_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
            "comparison_label": { "type": "string" },
            "comparison_value": { "type": ["number", "null"] },
            "severity": { "type": "string", "enum": ["info", "success", "warning", "critical"] },
            "visual_tone": { "type": "string", "enum": ["neutral", "positive", "caution", "critical"] },
            "source_authority_explanation": { "type": "string" },
            "trust_explanation": { "type": "string" },
            "freshness_explanation": { "type": "string" },
            "drilldown_hint": { "type": "string" },
            "empty_state_copy": { "type": "string" },
            "blocked_state_copy": { "type": "string" }
          }
        }
      }
    }
  }
}
