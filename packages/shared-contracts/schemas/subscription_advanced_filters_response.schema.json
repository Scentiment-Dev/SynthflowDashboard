{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscription Advanced Filters Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["module", "generated_from_fixture", "scenario", "options", "applied_filters", "metadata"],
  "properties": {
    "module": { "type": "string", "const": "subscriptions" },
    "generated_from_fixture": { "type": "boolean", "const": true },
    "scenario": { "type": "string" },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "filter_id",
          "label",
          "plain_language_help",
          "allowed_values",
          "is_enabled",
          "is_disabled_reason",
          "data_dependency",
          "source_system",
          "trust_impact",
          "applies_to_pages"
        ],
        "properties": {
          "filter_id": { "type": "string" },
          "label": { "type": "string" },
          "plain_language_help": { "type": "string" },
          "allowed_values": { "type": "array", "items": { "type": "string" } },
          "is_enabled": { "type": "boolean" },
          "is_disabled_reason": { "type": ["string", "null"] },
          "data_dependency": { "type": "string" },
          "source_system": { "type": "string" },
          "trust_impact": { "type": "string" },
          "applies_to_pages": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "applied_filters": { "type": "object" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "filters",
        "metric_definitions",
        "trust_label",
        "freshness_status",
        "formula_version",
        "owner",
        "timestamp",
        "fingerprint",
        "audit_reference",
        "source_confirmation_status",
        "presentation"
      ],
      "properties": {
        "metric_id": { "type": "string" },
        "filters": { "type": "object" },
        "metric_definitions": { "type": "array", "items": { "type": "string" } },
        "trust_label": { "type": "string", "enum": ["high", "medium", "low", "untrusted"] },
        "freshness_status": { "type": "string", "enum": ["fresh", "stale", "unknown"] },
        "formula_version": { "type": "string" },
        "owner": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fingerprint": { "type": "string" },
        "audit_reference": { "type": "string" },
        "source_confirmation_status": {
          "type": "string",
          "enum": ["confirmed", "pending", "missing"]
        },
        "presentation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "display_label",
            "short_label",
            "executive_summary",
            "format_type",
            "unit",
            "trend_direction",
            "comparison_label",
            "comparison_value",
            "severity",
            "visual_tone",
            "source_authority_explanation",
            "trust_explanation",
            "freshness_explanation",
            "drilldown_hint",
            "empty_state_copy",
            "blocked_state_copy"
          ],
          "properties": {
            "display_label": { "type": "string" },
            "short_label": { "type": "string" },
            "executive_summary": { "type": "string" },
            "format_type": { "type": "string" },
            "unit": { "type": "string" },
            "trend_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
            "comparison_label": { "type": "string" },
            "comparison_value": { "type": ["number", "null"] },
            "severity": { "type": "string", "enum": ["info", "success", "warning", "critical"] },
            "visual_tone": { "type": "string", "enum": ["neutral", "positive", "caution", "critical"] },
            "source_authority_explanation": { "type": "string" },
            "trust_explanation": { "type": "string" },
            "freshness_explanation": { "type": "string" },
            "drilldown_hint": { "type": "string" },
            "empty_state_copy": { "type": "string" },
            "blocked_state_copy": { "type": "string" }
          }
        }
      }
    }
  }
}
