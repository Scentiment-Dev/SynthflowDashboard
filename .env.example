METRIC_FRESHNESS_HARD_FAIL_MINUTES=240
TRUST_LABEL_MANUAL_ELEVATION_ALLOWED=false
HISTORICAL_BACKFILL_ENABLED=false
VITE_API_BASE_URL=http://localhost:8000
POSTGRES_DB=sdash
POSTGRES_USER=sdash
POSTGRES_PASSWORD=sdash
POSTGRES_PORT=5432
SYNTHFLOW_API_BASE_URL=
SYNTHFLOW_API_KEY=
STAYAI_API_BASE_URL=
STAYAI_API_KEY=
SHOPIFY_STORE_DOMAIN=
