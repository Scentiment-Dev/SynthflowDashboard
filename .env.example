APP_NAME=Scentiment Analytics API
APP_VERSION=0.3.0
APP_ENV=local
LOG_LEVEL=INFO
DOCS_ENABLED=true
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DATABASE_URL=postgresql+psycopg://sdash:sdash@postgres:5432/sdash
JWT_ISSUER=scentiment-internal
JWT_AUDIENCE=scentiment-analytics-dashboard
JWT_SECRET=change-me-local-only
EXPORT_FINGERPRINT_SECRET=change-me-local-only
