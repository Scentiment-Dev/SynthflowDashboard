{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subscription Follow-up Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["module", "generated_from_fixture", "scenario", "records", "metadata"],
  "properties": {
    "module": { "type": "string", "const": "subscriptions" },
    "generated_from_fixture": { "type": "boolean", "const": true },
    "scenario": { "type": "string" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "customer_or_case_id",
          "recommended_action",
          "reason",
          "priority",
          "status",
          "source_system",
          "blocking_data_gap",
          "stayai_confirmation_status",
          "portal_completion_status",
          "estimated_value_at_risk",
          "last_event_at",
          "owner_queue",
          "sla_status",
          "audit_reference",
          "support_label",
          "support_summary",
          "why_it_matters",
          "what_to_do_next",
          "blocked_reason_plain_language"
        ],
        "properties": {
          "customer_or_case_id": { "type": "string" },
          "recommended_action": { "type": "string" },
          "reason": { "type": "string" },
          "priority": { "type": "string" },
          "status": { "type": "string" },
          "source_system": { "type": "string" },
          "blocking_data_gap": { "type": ["string", "null"] },
          "stayai_confirmation_status": { "type": "string", "enum": ["confirmed", "pending", "missing"] },
          "portal_completion_status": { "type": "string" },
          "estimated_value_at_risk": { "type": ["number", "null"] },
          "last_event_at": { "type": "string", "format": "date-time" },
          "owner_queue": { "type": "string" },
          "sla_status": { "type": "string" },
          "audit_reference": { "type": "string" },
          "support_label": { "type": "string" },
          "support_summary": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "what_to_do_next": { "type": "string" },
          "blocked_reason_plain_language": { "type": ["string", "null"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "filters",
        "metric_definitions",
        "trust_label",
        "freshness_status",
        "formula_version",
        "owner",
        "timestamp",
        "fingerprint",
        "audit_reference",
        "source_confirmation_status",
        "presentation"
      ],
      "properties": {
        "metric_id": { "type": "string" },
        "filters": { "type": "object" },
        "metric_definitions": { "type": "array", "items": { "type": "string" } },
        "trust_label": { "type": "string", "enum": ["high", "medium", "low", "untrusted"] },
        "freshness_status": { "type": "string", "enum": ["fresh", "stale", "unknown"] },
        "formula_version": { "type": "string" },
        "owner": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fingerprint": { "type": "string" },
        "audit_reference": { "type": "string" },
        "source_confirmation_status": {
          "type": "string",
          "enum": ["confirmed", "pending", "missing"]
        },
        "presentation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "display_label",
            "short_label",
            "executive_summary",
            "format_type",
            "unit",
            "trend_direction",
            "comparison_label",
            "comparison_value",
            "severity",
            "visual_tone",
            "source_authority_explanation",
            "trust_explanation",
            "freshness_explanation",
            "drilldown_hint",
            "empty_state_copy",
            "blocked_state_copy"
          ],
          "properties": {
            "display_label": { "type": "string" },
            "short_label": { "type": "string" },
            "executive_summary": { "type": "string" },
            "format_type": { "type": "string" },
            "unit": { "type": "string" },
            "trend_direction": { "type": "string", "enum": ["up", "down", "flat", "unknown"] },
            "comparison_label": { "type": "string" },
            "comparison_value": { "type": ["number", "null"] },
            "severity": { "type": "string", "enum": ["info", "success", "warning", "critical"] },
            "visual_tone": { "type": "string", "enum": ["neutral", "positive", "caution", "critical"] },
            "source_authority_explanation": { "type": "string" },
            "trust_explanation": { "type": "string" },
            "freshness_explanation": { "type": "string" },
            "drilldown_hint": { "type": "string" },
            "empty_state_copy": { "type": "string" },
            "blocked_state_copy": { "type": "string" }
          }
        }
      }
    }
  }
}
