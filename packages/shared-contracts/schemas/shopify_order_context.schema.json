{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Shopify Order Context",
  "required": [
    "order_id",
    "created_at"
  ],
  "properties": {
    "order_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shipping_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "fulfillment_status": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
